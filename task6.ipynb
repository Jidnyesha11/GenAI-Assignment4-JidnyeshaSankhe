   "source": [
    "import os\n",
    "\n",
    "filename = input(\"Enter the file name: \")\n",
    "\n",
    "if os.path.exists(filename):\n",
    "\n",
    "    with open(filename, \"r\") as file:\n",
    "\n",
    "        data = file.read()\n",
    "\n",
    "        print(\"File Contents:\")\n",
    "\n",
    "        print(data)\n",
    "\n",
    "else:\n",
    "\n",
    "    print(\"Error: File does not exist.\")"
   ]
  }
 ],
